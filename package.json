{
  "name": "inkflow",
  "version": "1.4.1",
  "description": "A high-performance manga reader with offline support.",
  "productName": "Inkflow",
  "main": "main.js",
  "author": "Zigby",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/zigby33-sudo/inkflow.git"
  },
  "publish": [
    {
      "provider": "github",
      "owner": "zigby33-sudo",
      "repo": "inkflow"
    }
  ],
  "scripts": {
    "run": "electron .",
    "start": "electron-forge start",
    "package": "electron-forge package",
    "make": "electron-forge make",
    "publish": "electron-forge publish"
  },
  "config": {
    "forge": {
      "packagerConfig": {
        "asar": true,
        "icon": "assets/logo"
      },
      "rebuildConfig": {},
      "makers": [
        {
          "name": "@electron-forge/maker-squirrel",
          "config": {
            "authors": "Zigby",
            "description": "A high-performance manga reader with offline support.",
            "setupIcon": "assets/logo.ico",
            "loadingGif": "assets/installing.gif"
          }
        },
        {
          "name": "@electron-forge/maker-zip",
          "platforms": [
            "darwin"
          ]
        }
      ],
      "plugins": [
        {
          "name": "@electron-forge/plugin-auto-unpack-natives",
          "config": {}
        }
      ],
      "publishers": [
        {
          "name": "@electron-forge/publisher-github",
          "config": {
            "repository": {
              "owner": "zigby33-sudo",
              "name": "inkflow"
            },
            "draft": false,
            "prerelease": false
          }
        }
      ]
    }
  },
  "dependencies": {
    "electron-squirrel-startup": "^1.0.1",
    "fs-extra": "^11.2.0",
    "matcher": "^5.0.0",
    "ms": "^2.1.3",
    "pump": "^3.0.0"
  },
  "devDependencies": {
    "@electron-forge/cli": "^7.11.1",
    "@electron-forge/maker-squirrel": "^7.11.1",
    "@electron-forge/maker-zip": "^7.11.1",
    "@electron-forge/plugin-auto-unpack-natives": "^7.11.1",
    "@electron-forge/publisher-github": "^7.11.1",
    "electron": "^30.5.1"
  }
}
